meta {
  name: add-device-type
  type: http
  seq: 3
}

post {
  url: http://localhost:3000/api/device-type
  body: json
  auth: inherit
}

body:json {
  {
    "brandName": "Dell",
    "deviceKind": "Laptop",
    "description": "i7-10th Generation",
    "brandLogo": "dell.svg"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
